# Build context: repo root
# docker build -f services/detector/Dockerfile.x86 -t openring-detector-x86 .
#
# x86/CUDA detector image.  Uses GPU when NVIDIA runtime is available,
# falls back to CPU inference when it is not.
# Not digest-pinned: Docker does not support @sha256 with ARG interpolation.
# Pin is handled by the tag version; override requires explicit tag.
ARG PYTORCH_TAG=2.6.0-cuda12.4-cudnn9-runtime
FROM pytorch/pytorch:${PYTORCH_TAG}

# OpenCV headless deps (no GStreamer needed on x86 — cv2 handles RTSP directly)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    gosu \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps before copying source (layer caching)
# torch / torchvision / torchaudio are provided by the pytorch base image.
# Do NOT add them here — pip will skip reinstalling compatible versions.
COPY services/detector/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source
COPY services/detector/src/ ./src/
COPY shared/ ./shared/

# Both src/ and shared/ on the path
ENV PYTHONPATH=/app/src:/app/shared
ENV PYTHONUNBUFFERED=1
ENV YOLO_CONFIG_DIR=/tmp/ultralytics

# Create non-root user for defense in depth.
# The video group provides GPU device access on most Linux hosts.
# Container starts as root; entrypoint fixes volume ownership then drops
# to openring via gosu.
RUN useradd -r -m -d /home/openring -s /usr/sbin/nologin -G video openring && \
    mkdir -p /data /config /models /tmp/ultralytics && \
    chown openring:openring /data /config /models /tmp/ultralytics

COPY services/detector/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python3", "src/main.py"]
